# Azure Storage  (populated automatically by setup_dev.sh via az CLI)
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
AZURE_CLIENT_SECRET=<your-client-secret>
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net

# AWS / LocalStack
# Set LOCALSTACK_ENDPOINT to route SQS calls to LocalStack instead of real AWS
# Leave empty for production
AWS_REGION=us-east-1
LOCALSTACK_ENDPOINT=http://localhost:4566
SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/my-queue

# Poller settings
CURSOR_FILE=.changefeed_cursor.json
POLL_INTERVAL_SECONDS=60
